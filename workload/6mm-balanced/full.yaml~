workload:
  iteration_space_shape:
    v: 0 <= v < 128
    w: 0 <= w < 128
    x: 0 <= x < 128
    y: 0 <= y < 128
    z: 0 <= z < 128
    k: 0 <= k < 128
    m: 0 <= m < 128
    n: 0 <= n < 128
    q: 0 <= q < 128
  bits_per_value: {All: 8}

  einsums:
  - name: AB
    tensor_accesses:
    - {name: A, projection: [v, w]}
    - {name: B, projection: [w, x]}
    - {name: AB, projection: [v, x], output: True}
    renames: {input: A}
  
  - name: CD
    tensor_accesses:
    - {name: C, projection: [x, y]}
    - {name: D, projection: [y, z]}
    - {name: CD, projection: [x, z], output: True}
    renames: {input: C}
  
  - name: EF
    tensor_accesses:
    - {name: E, projection: [z, k]}
    - {name: F, projection: [k, m]}
    - {name: EF, projection: [z, m], output: True}
    renames: {input: E}
  
  - name: GH
    tensor_accesses:
    - {name: G, projection: [m, n]}
    - {name: H, projection: [n, q]}
    - {name: GH, projection: [m, q], output: True}
    renames: {input: G}
  
  - name: ABCD
    tensor_accesses:
    - {name: AB, projection: [v, x]}
    - {name: CD, projection: [x, z]}
    - {name: ABCD, projection: [v, z], output: True}
    renames: {input: AB}
  
  - name: EFGH
    tensor_accesses:
    - {name: EF, projection: [z, m]}
    - {name: GH, projection: [m, q]}
    - {name: EFGH, projection: [z, q], output: True}
    renames: {input: EF}
  
  - name: OUT
    tensor_accesses:
    - {name: ABCD, projection: [v, z]}
    - {name: EFGH, projection: [z, q]}
    - {name: OUT, projection: [v, q], output: True}
    renames: {input: ABCD}

renames:
  einsums:
  - name: default
    tensor_accesses:
    - name: input
      source: Inputs & Intermediates
      expected_count: 1
    - name: output
      source: Outputs
      expected_count: 1
    - name: weight
      source: ~(input | output)
      expected_count: 1
